@import "_variables"
*,
*:after,
*:before{
	-webkit-box-sizing: border-box;
	-moz-box-sizing: border-box;
	box-sizing: border-box;
	margin: 0
	padding: 0
	list-style: none
	text-decoration: none
	border: none
	outline: none
	color: white
	font-family: 'Noto Sans', sans-serif;
}
* a
	color: #0d0d0d
body
	background-color: #0d0d0d