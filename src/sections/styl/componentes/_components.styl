@import "../../../styl/foundations/_variables"
@import "../../../styl/foundations/_default"
body
  display: grid
  grid-template-columns: auto auto
  grid-template-areas: "header body"
  max-height: 100vh
  width: 100vw

.header
 grid-area: header

.main 
  grid-area: body
  & h1
    text-align: center
    font-size: 20px
    margin-top: 20px
.components
  grid-area: body
  display: flex
  flex-direction: column
  justify-content: space-evenly
  height 100vh
  max-width 60vw
  align-items: center
  margin-left: 15%

.container
  // border: 2px solid #1e3f7c
  &__name
    font-medium()
    text-align: center
  &__use
    font-normal()
  & ul
    padding: unity
    // background-color: #4222e1

@media screen and (max-width 320px)
  .container
    & h2
      font-small()
    & ul li
      font-small()